MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/vidhyaplus
JWT_SECRET=replace-with-a-long-random-string
PORT=5000
NODE_ENV=development
FAST2SMS_API_KEY=your-fast2sms-key

# FIX #5: comma-separated list of exact frontend origins allowed to call this API.
# CORS was previously origin: '*' — must be locked down before deploying.
ALLOWED_ORIGINS=http://localhost:3000,https://vidhyaplus.vercel.app
